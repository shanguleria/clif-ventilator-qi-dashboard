.venv/
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.DS_Store

# Site-specific config (legacy single-site config.json; superseded by sites/<site>.json)
config.json
metrics/*/config.json
metrics/*/config/config.json

# Per-site profiles hold local data paths — site-local, gitignored. Commit sites/*.example.json only.
# (definitions/ is the shared, versioned clinical spec and IS committed.)
sites/*.json
!sites/*.example.json

# Internal working logs and design docs (not part of the shared template)
.claude/
plans/

# Brand/tile artwork (local; the scorecard + dashboard fall back to inline SVG without them).
# NOTE: kept out of the public repo because the illustrations are borrowed from the design
# inspiration. Revisit in Phase 4 if we license/replace them and want clones to render branded.
assets/
metrics/*/references/images/

# Generated outputs and intermediate data — kept out of git
output/
*.parquet
*.csv

# Collected tile feeds (build artifacts regenerated by the scorecard; feeds/.gitkeep is tracked)
feeds/*.json

# Editor / OS cruft
.vscode/
.idea/
*.swp
